<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>我的精美网站</title>
  <link rel="stylesheet" href="css/style.css">
  <style>
    /* 新增动画样式 */
    @keyframes fadeInDown {
      from {
        opacity: 0;
        transform: translateY(-50px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes scaleIn {
      from {
        opacity: 0;
        transform: scale(0.8);
      }
      to {
        opacity: 1;
        transform: scale(1);
      }
    }

    @keyframes bounceIn {
      0% {
        opacity: 0;
        transform: scale(0.3);
      }
      50% {
        opacity: 1;
        transform: scale(1.05);
      }
      70% {
        transform: scale(0.9);
      }
      100% {
        opacity: 1;
        transform: scale(1);
      }
    }

    @keyframes typewriter {
      from { width: 0 }
      to { width: 100% }
    }

    @keyframes blink {
      50% { border-color: transparent }
    }

    @keyframes float {
      0%, 100% {
        transform: translateY(0px);
      }
      50% {
        transform: translateY(-20px);
      }
    }

    @keyframes glow {
      0%, 100% {
        box-shadow: 0 0 20px rgba(102, 126, 234, 0.5);
      }
      50% {
        box-shadow: 0 0 40px rgba(102, 126, 234, 0.8);
      }
    }

    .fade-in-down {
      animation: fadeInDown 1s ease-out;
    }

    .scale-in {
      animation: scaleIn 0.8s ease-out;
    }

    .bounce-in {
      animation: bounceIn 1s ease-out;
    }

    .float-animation {
      animation: float 3s ease-in-out infinite;
    }

    .glow-effect {
      animation: glow 2s ease-in-out infinite;
    }

    .delay-1 { animation-delay: 0.2s; }
    .delay-2 { animation-delay: 0.4s; }
    .delay-3 { animation-delay: 0.6s; }
    .delay-4 { animation-delay: 0.8s; }
    .delay-5 { animation-delay: 1.0s; }
    .delay-6 { animation-delay: 1.2s; }
    .delay-7 { animation-delay: 1.4s; }
    .delay-8 { animation-delay: 1.6s; }
  </style>
</head>
<body>
  <!-- 背景音频 -->
  <audio id="bgMusic" loop>
    <source src="audio.wav" type="audio/wav">
    您的浏览器不支持音频播放
  </audio>

  <!-- 音频控制按钮 -->
  <button class="audio-control" id="audioControl" title="播放/暂停音乐">
    🔊
  </button>

  <!-- 主容器 -->
  <div class="container">
    <!-- Hero 区域 -->
    <section class="hero-section">
      <div class="hero-content">
        <h1 class="hero-title fade-in-down">欢迎来到我的世界</h1>
        <p class="hero-subtitle fade-up delay-1">探索无限可能</p>
        <p class="hero-description fade-up delay-2">
          在这里，每一帧都是艺术，每一个细节都充满惊喜
        </p>
        <button class="cta-button bounce-in delay-3">开始探索</button>
      </div>
    </section>

    <!-- 特色介绍 -->
    <section class="feature-section">
      <h2 class="section-title fade-in-down">我们的特色</h2>
      <div class="feature-grid">
        <div class="feature-card fade-up delay-1">
          <div class="feature-icon">✨</div>
          <h3 class="feature-title">精美设计</h3>
          <p class="feature-description">
            每一个元素都经过精心设计，带来极致的视觉体验
          </p>
        </div>
        <div class="feature-card fade-up delay-2">
          <div class="feature-icon">🎨</div>
          <h3 class="feature-title">创意无限</h3>
          <p class="feature-description">
            融合艺术与技术，创造出独一无二的作品
          </p>
        </div>
        <div class="feature-card fade-up delay-3">
          <div class="feature-icon">🚀</div>
          <h3 class="feature-title">流畅体验</h3>
          <p class="feature-description">
            优化的动画效果，让每一次交互都充满愉悦
          </p>
        </div>
      </div>
    </section>

    <!-- 图片展示 -->
    <section class="gallery-section">
      <h2 class="section-title fade-in-down">精彩瞬间</h2>
      <div class="gallery-grid">
        <div class="gallery-item scale-in delay-1">
          <div class="gallery-placeholder float-animation" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
            <span class="placeholder-icon">🖼️</span>
          </div>
          <div class="gallery-caption">创意作品</div>
        </div>
        <div class="gallery-item scale-in delay-2">
          <div class="gallery-placeholder float-animation" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); animation-delay: 0.5s;">
            <span class="placeholder-icon">🌟</span>
          </div>
          <div class="gallery-caption">精彩瞬间</div>
        </div>
        <div class="gallery-item scale-in delay-3">
          <div class="gallery-placeholder float-animation" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); animation-delay: 1s;">
            <span class="placeholder-icon">💫</span>
          </div>
          <div class="gallery-caption">灵感来源</div>
        </div>
        <div class="gallery-item scale-in delay-4">
          <div class="gallery-placeholder float-animation" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); animation-delay: 1.5s;">
            <span class="placeholder-icon">🎯</span>
          </div>
          <div class="gallery-caption">目标达成</div>
        </div>
        <div class="gallery-item scale-in delay-5">
          <div class="gallery-placeholder float-animation" style="background: linear-gradient(135deg, #fa709a 0%, #fee140 100%); animation-delay: 2s;">
            <span class="placeholder-icon">🌈</span>
          </div>
          <div class="gallery-caption">多彩生活</div>
        </div>
        <div class="gallery-item scale-in delay-6">
          <div class="gallery-placeholder float-animation" style="background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%); animation-delay: 2.5s;">
            <span class="placeholder-icon">🎪</span>
          </div>
          <div class="gallery-caption">欢乐时光</div>
        </div>
      </div>
    </section>

    <!-- 文字内容区 -->
    <section class="text-section">
      <div class="text-content">
        <h2 class="section-title fade-in-down">关于我们</h2>
        <p class="fade-up delay-1">
          我们是一群热爱创意和技术的团队，致力于将艺术与科技完美融合。每一个项目都是我们对美好生活的诠释，每一个作品都承载着我们的梦想与热情。
        </p>
        <p class="fade-up delay-2">
          在这里，我们不只是展示作品，更是分享故事。每一个设计背后都有着独特的创意过程，每一个动画都蕴含着我们对细节的执着追求。
        </p>
        <p class="fade-up delay-3">
          我们相信，优秀的设计不仅仅是视觉上的美感，更是情感的共鸣。通过精心编排的动画和交互，我们希望能够触动每一位访客的心灵。
        </p>
        <p class="fade-up delay-4">
          欢迎来到我们的世界，让我们一起探索创意的无限可能，在艺术与技术的交汇点上，创造更多令人惊叹的作品。
        </p>
      </div>
    </section>

    <!-- 数据统计 -->
    <section class="stats-section">
      <h2 class="section-title fade-in-down">我们的成就</h2>
      <div class="stats-grid">
        <div class="stat-item bounce-in delay-1">
          <div class="stat-number glow-effect">100+</div>
          <div class="stat-label">创意作品</div>
        </div>
        <div class="stat-item bounce-in delay-2">
          <div class="stat-number glow-effect">50+</div>
          <div class="stat-label">合作客户</div>
        </div>
        <div class="stat-item bounce-in delay-3">
          <div class="stat-number glow-effect">5</div>
          <div class="stat-label">年经验</div>
        </div>
        <div class="stat-item bounce-in delay-4">
          <div class="stat-number glow-effect">∞</div>
          <div class="stat-label">创意无限</div>
        </div>
      </div>
    </section>

    <!-- 联系我们 -->
    <section class="contact-section">
      <div class="contact-content fade-up">
        <h2 class="section-title">联系我们</h2>
        <p>如果你有任何想法或合作意向，欢迎随时联系我们</p>
        <div class="contact-buttons">
          <button class="contact-button">发送邮件</button>
          <button class="contact-button">关注我们</button>
        </div>
      </div>
    </section>

    <!-- 页脚 -->
    <footer class="footer">
      <p>© 2024 我的精美网站. All rights reserved.</p>
    </footer>
  </div>

  <script src="js/main.js"></script>
</body>
</html>